# Anthropic API 키 (필수) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# 접속 비밀번호 (선택) — 설정하지 않으면 비밀번호 없이 접속
SITE_PASSWORD=your-password-here

# 토큰 서명 시크릿 (선택, 미설정 시 자동 처리)
TOKEN_SECRET=random-long-secret-string

# Supabase 벡터 RAG (선택) — supabase-setup.sql을 먼저 실행한 후 설정
# https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
